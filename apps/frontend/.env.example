# OpenRouteService API key (free tier available at openrouteservice.org)
# Required for routing (ORS) and isochrone features.
# If not set, those features will show a descriptive error.
ORS_API_KEY=

# Default points used across all modules
# POINT1: primary location (used by single-point modules like OSM Explorer, Geofencing check) 30.044950, 31.236149
# POINT2: secondary/destination location (used by two-point modules like Routing, Live Tracking)  31.049404, 31.404497
NEXT_PUBLIC_POINT1_LAT=30.044950
NEXT_PUBLIC_POINT1_LNG=31.236149
NEXT_PUBLIC_POINT2_LAT=31.049404
NEXT_PUBLIC_POINT2_LNG=31.404497
